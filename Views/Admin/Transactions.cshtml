@model List<BookBridge.Models.Entities.Transaction>
@{
    ViewData["Title"] = "Transactions";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<h2 style="font-family:var(--font-body);font-weight:600;margin-bottom:20px;">All Transactions</h2>

<div class="admin-table">
    <table class="table">
        <thead>
            <tr><th>#</th><th>Book</th><th>Buyer</th><th>Seller</th><th>Type</th><th>Amount</th><th>Status</th><th>Date</th></tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td style="font-size:0.8rem;color:var(--text-muted);">#@t.Id</td>
                    <td style="font-size:0.875rem;font-weight:600;">@t.Book?.Title</td>
                    <td style="font-size:0.875rem;">@t.Buyer?.FullName</td>
                    <td style="font-size:0.875rem;">@t.Seller?.FullName</td>
                    <td><span class="chip" style="font-size:0.65rem;">@t.Type</span></td>
                    <td style="font-family:var(--font-body);font-weight:700;color:var(--emerald);">
                        Rs. @t.Amount.ToString("N0")
                    </td>
                    <td>
                        <span class="status-badge badge-@t.Status.ToString().ToLower()">@t.Status</span>
                    </td>
                    <td style="font-size:0.8rem;color:var(--text-muted);">@t.CreatedAt.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-receipt" style="font-size:3rem;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
        <h5>No transactions yet</h5>
    </div>
}
