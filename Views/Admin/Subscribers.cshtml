@model List<BookBridge.Models.Entities.NewsletterSubscription>
@{
    ViewData["Title"] = "Subscribers";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="row g-4">
    <!-- Left Column: Subscribers List -->
    <div class="col-lg-7">
        <h2 style="font-family:var(--font-body);font-weight:600;margin-bottom:20px;">Newsletter Subscribers</h2>

        <div class="admin-table">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Email Address</th>
                        <th>Subscribed Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int count = 1;
                        @foreach (var sub in Model)
                        {
                            <tr>
                                <td style="font-size:0.875rem;color:var(--text-muted);">@count</td>
                                <td style="font-size:0.875rem;font-weight:600;">@sub.Email</td>
                                <td style="font-size:0.875rem;color:var(--text-muted);">@sub.SubscribedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</td>
                            </tr>
                            count++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="bi bi-envelope-open" style="font-size:2.5rem;display:block;margin-bottom:8px;opacity:0.5;"></i>
                                No newsletter subscribers yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Right Column: Send Announcement Form -->
    <div class="col-lg-5">
        <div class="analytics-card p-4">
            <h4 style="font-family:var(--font-body);font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:10px;">
                <i class="bi bi-megaphone text-primary"></i> Send Announcement
            </h4>
            <p class="text-muted small mb-4">
                This will publish a dashboard notification to all registered users who have subscribed to the newsletter.
            </p>

            <form asp-controller="Admin" asp-action="SendAnnouncement" method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.85rem;font-weight:600;">Announcement Title</label>
                    <input name="title" class="form-control bb-input" placeholder="e.g., New Book Releases!" required />
                </div>
                <div class="mb-4">
                    <label class="form-label" style="font-size:0.85rem;font-weight:600;">Message Content</label>
                    <textarea name="message" class="form-control bb-input" rows="5"
                              placeholder="Type your message here..." required></textarea>
                </div>
                <button type="submit" class="btn bb-btn-primary w-100">
                    <i class="bi bi-send-fill me-2"></i>Send Announcement
                </button>
            </form>
        </div>
    </div>
</div>
