@* Dashboard/Profile.cshtml *@
@model BookBridge.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="row g-4">
    <!-- Profile Card -->
    <div class="col-lg-4">
        <div class="analytics-card text-center p-5">
            <div class="position-relative d-inline-block mb-4">
                <img src="@(Model.User.ProfilePicture ?? "/images/default-avatar.png")"
                     alt="@Model.User.FullName"
                     style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:4px solid var(--border);"
                     onerror="this.src='/images/default-avatar.png'" />
                @if (Model.User.IsVerified)
                {
                    <div style="position:absolute;bottom:4px;right:4px;background:var(--emerald);color:white;border-radius:50%;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border:2px solid white;">
                        <i class="bi bi-patch-check-fill" style="font-size:0.75rem;"></i>
                    </div>
                }
            </div>

            <h3 style="font-family:var(--font-body);font-weight:600;margin-bottom:4px;">@Model.User.FullName</h3>
            <p class="text-muted mb-2">@Model.User.Email</p>

            @if (!string.IsNullOrEmpty(Model.User.City))
            {
                <p class="text-muted mb-3" style="font-size:0.875rem;">
                    <i class="bi bi-geo-alt me-1"></i>@Model.User.City
                </p>
            }

            <div class="d-flex justify-content-center gap-1 mb-3">
                <div class="stars">
                    @for (int i = 1; i <= 5; i++) { @(i <= Math.Round(Model.User.AverageRating) ? "★" : "☆") }
                </div>
                <span style="font-size:0.85rem;color:var(--text-muted);">(@Model.User.TotalRatings reviews)</span>
            </div>

            <div class="row g-2 mb-4">
                <div class="col-4">
                    <div style="background:rgba(37,99,235,0.06);border-radius:var(--radius-sm);padding:12px 4px;">
                        <div style="font-family:var(--font-body);font-size:1.3rem;font-weight:600;color:var(--primary);">@Model.Books.Count</div>
                        <div style="font-size:0.7rem;color:var(--text-muted);">Listed</div>
                    </div>
                </div>
                <div class="col-4">
                    <div style="background:rgba(16,185,129,0.06);border-radius:var(--radius-sm);padding:12px 4px;">
                        <div style="font-family:var(--font-body);font-size:1.3rem;font-weight:600;color:var(--emerald);">@Model.Reviews.Count</div>
                        <div style="font-size:0.7rem;color:var(--text-muted);">Reviews</div>
                    </div>
                </div>
                <div class="col-4">
                    <div style="background:rgba(245,158,11,0.06);border-radius:var(--radius-sm);padding:12px 4px;">
                        <div style="font-family:var(--font-body);font-size:1.3rem;font-weight:600;color:var(--amber);">
                            @(Model.User.IsVerified ? "✓" : "—")
                        </div>
                        <div style="font-size:0.7rem;color:var(--text-muted);">Verified</div>
                    </div>
                </div>
            </div>

            <a asp-controller="Dashboard" asp-action="EditProfile" class="btn bb-btn-primary w-100">
                <i class="bi bi-pencil me-2"></i>Edit Profile
            </a>

            <div class="mt-3 text-muted" style="font-size:0.78rem;">
                Member since @Model.User.CreatedAt.ToString("MMMM yyyy")
            </div>
        </div>
    </div>

    <!-- Details + Reviews -->
    <div class="col-lg-8">
        <!-- Account Info -->
        <div class="analytics-card mb-4">
            <h5 style="font-family:var(--font-body);font-weight:700;margin-bottom:20px;">Account Information</h5>
            <div class="row g-3">
                @{
                    var fields = new[] {
                        ("Full Name", Model.User.FullName, "bi-person"),
                        ("Email", Model.User.Email ?? "", "bi-envelope"),
                        ("Phone", Model.User.PhoneNumber ?? "Not provided", "bi-phone"),
                        ("City", Model.User.City ?? "Not provided", "bi-geo-alt"),
                        ("Address", Model.User.Address ?? "Not provided", "bi-house"),
                        ("CNIC", string.IsNullOrEmpty(Model.User.CNIC) ? "Not provided" : "••••••••••••••", "bi-card-text"),
                    };
                }
                @foreach (var (label, value, icon) in fields)
                {
                    <div class="col-md-6">
                        <div style="display:flex;align-items:flex-start;gap:10px;padding:12px;border-radius:var(--radius-sm);background:rgba(248,250,255,0.8);border:1px solid var(--border);">
                            <i class="bi @icon" style="color:var(--primary);margin-top:2px;"></i>
                            <div style="flex:1;">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--text-muted);">@label</span>
                                    
                                    @if (label == "Email")
                                    {
                                        if (Model.User.EmailConfirmed)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill py-0.5 px-2" style="font-size: 0.68rem; font-weight: 600;"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Account" asp-action="VerifyEmail" asp-route-email="@Model.User.Email" class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill py-0.5 px-2 text-decoration-none" style="font-size: 0.68rem; font-weight: 600;"><i class="bi bi-exclamation-triangle-fill me-1"></i>Verify Now</a>
                                        }
                                    }
                                    else if (label == "Phone")
                                    {
                                        if (Model.User.PhoneNumberConfirmed)
                                        {
                                            <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill py-0.5 px-2" style="font-size: 0.68rem; font-weight: 600;"><i class="bi bi-patch-check-fill me-1"></i>Verified</span>
                                        }
                                        else if (!string.IsNullOrEmpty(Model.User.PhoneNumber) && Model.User.PhoneNumber != "Not provided")
                                        {
                                            <a asp-controller="Account" asp-action="VerifyPhone" asp-route-email="@Model.User.Email" class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-pill py-0.5 px-2 text-decoration-none" style="font-size: 0.68rem; font-weight: 600;"><i class="bi bi-exclamation-triangle-fill me-1"></i>Verify Now</a>
                                        }
                                    }
                                </div>
                                <div style="font-size:0.875rem;font-weight:500;margin-top:2px;">@value</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Reviews Received -->
        <div class="analytics-card">
            <h5 style="font-family:var(--font-body);font-weight:700;margin-bottom:20px;">
                Reviews <span style="color:var(--text-muted);font-size:0.85rem;">(@Model.Reviews.Count)</span>
            </h5>

            @if (Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews.Take(5))
                {
                    <div class="d-flex gap-3 p-3 rounded-3 mb-3" style="border:1px solid var(--border);">
                        <img src="@(review.Reviewer?.ProfilePicture ?? "/images/default-avatar.png")"
                             style="width:40px;height:40px;border-radius:50%;object-fit:cover;flex-shrink:0;"
                             onerror="this.src='/images/default-avatar.png'" />
                        <div style="flex:1;">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div style="font-weight:600;font-size:0.875rem;">@review.Reviewer?.FullName</div>
                                <div style="font-size:0.75rem;color:var(--text-muted);">@review.CreatedAt.ToString("dd MMM yyyy")</div>
                            </div>
                            <div class="stars" style="font-size:0.85rem;margin-bottom:6px;">
                                @for (int i = 1; i <= 5; i++) { @(i <= review.Rating ? "★" : "☆") }
                            </div>
                            @if (!string.IsNullOrEmpty(review.Comment))
                            {
                                <p style="font-size:0.875rem;color:var(--text-secondary);margin:0;line-height:1.6;">@review.Comment</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-4 text-muted">
                    <i class="bi bi-star" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                    No reviews yet
                </div>
            }
        </div>
    </div>
</div>
