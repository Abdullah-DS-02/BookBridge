@* Dashboard/Transactions.cshtml *@
@model List<BookBridge.Models.Entities.Transaction>
@{
    ViewData["Title"] = "Transaction History";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 style="font-family:var(--font-body);font-weight:600;margin-bottom:20px;">Transaction History</h2>

@if (Model.Any())
{
    <div class="admin-table">
        <table class="table">
            <thead>
                <tr>
                    <th>#</th><th>Book</th><th>Type</th><th>With</th>
                    <th>Amount</th><th>Status</th><th>Date</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                }
                @foreach (var t in Model)
                {
                    bool isBuyer = t.BuyerId == currentUserId;
                    <tr>
                        <td style="font-size:0.8rem;color:var(--text-muted);">#@t.Id</td>
                        <td>
                            <div style="font-weight:600;font-size:0.875rem;">@t.Book?.Title</div>
                            <div style="font-size:0.75rem;color:var(--text-muted);">@t.Type</div>
                        </td>
                        <td><span class="chip" style="font-size:0.7rem;">@t.Type</span></td>
                        <td style="font-size:0.875rem;">@(isBuyer ? t.Seller?.FullName : t.Buyer?.FullName)</td>
                        <td style="font-family:var(--font-body);font-weight:700;color:@(isBuyer ? "var(--rose)" : "var(--emerald)");">
                            @(isBuyer ? "-" : "+")Rs. @t.Amount.ToString("N0")
                        </td>
                        <td><span class="status-badge badge-@t.Status.ToString().ToLower()">@t.Status</span></td>
                        <td style="font-size:0.8rem;color:var(--text-muted);">@t.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-receipt" style="font-size:3rem;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
        <h5>No transactions yet</h5>
        <p class="text-muted">Your buy/sell history will appear here.</p>
    </div>
}
