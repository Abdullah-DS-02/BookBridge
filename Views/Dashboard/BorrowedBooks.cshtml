@* Dashboard/BorrowedBooks.cshtml *@
@model List<BookBridge.Models.Entities.BorrowRequest>
@{
    ViewData["Title"] = "Borrowed Books";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<h2 style="font-family:var(--font-body);font-weight:600;margin-bottom:20px;">Borrowed Books</h2>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var req in Model)
        {
            var img = req.Book?.Images?.FirstOrDefault(i => i.IsPrimary)?.ImagePath ?? req.Book?.Images?.FirstOrDefault()?.ImagePath ?? "/images/book-placeholder.png";
            var daysLeft = req.DueDate.HasValue ? (int)(req.DueDate.Value - DateTime.UtcNow).TotalDays : 0;
            <div class="col-md-6 col-lg-4">
                <div class="analytics-card @(req.IsLate ? "border-danger" : "")" style="@(req.IsLate ? "border-color:var(--rose)!important;" : "")">
                    <div class="d-flex gap-3 mb-4">
                        <img src="@img" style="width:70px;height:90px;object-fit:cover;border-radius:var(--radius-sm);"
                             onerror="this.src='/images/book-placeholder.png'" />
                        <div>
                            <div style="font-weight:700;font-size:0.95rem;margin-bottom:4px;">@req.Book?.Title</div>
                            <div style="font-size:0.8rem;color:var(--text-muted);">@req.Book?.Author</div>
                            <div style="font-size:0.8rem;margin-top:6px;">From: <strong>@req.Owner?.FullName</strong></div>
                        </div>
                    </div>

                    @if (req.IsLate)
                    {
                        <div class="p-2 rounded-2 mb-3" style="background:rgba(244,63,94,0.1);border:1px solid rgba(244,63,94,0.2);">
                            <div style="font-size:0.85rem;font-weight:700;color:var(--rose);">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i>OVERDUE — Please return immediately!
                            </div>
                        </div>
                    }
                    else if (req.DueDate.HasValue)
                    {
                        <div class="borrow-countdown" data-due-date="@req.DueDate.Value.ToString("O")">
                            <div style="font-size:0.8rem;font-weight:600;margin-bottom:8px;color:var(--amber);">
                                <i class="bi bi-clock me-1"></i>Time Remaining
                            </div>
                            <div class="countdown-timer" style="justify-content:flex-start;gap:8px;">
                                <div class="countdown-unit" style="min-width:46px;">
                                    <div class="countdown-number" data-days style="font-size:1.3rem;">@daysLeft</div>
                                    <div class="countdown-label">Days</div>
                                </div>
                                <div class="countdown-unit" style="min-width:46px;">
                                    <div class="countdown-number" data-hours style="font-size:1.3rem;">--</div>
                                    <div class="countdown-label">Hrs</div>
                                </div>
                                <div class="countdown-unit" style="min-width:46px;">
                                    <div class="countdown-number" data-mins style="font-size:1.3rem;">--</div>
                                    <div class="countdown-label">Min</div>
                                </div>
                            </div>
                            <div style="font-size:0.75rem;color:var(--text-muted);margin-top:8px;">Due: @req.DueDate.Value.ToString("dd MMM yyyy")</div>
                        </div>
                    }

                    <form asp-controller="Books" asp-action="ReturnBook" method="post" class="mt-3">
                        <input type="hidden" name="requestId" value="@req.Id" />
                        <button type="submit" class="btn bb-btn-primary w-100 btn-sm"
                                data-confirm="Confirm return of '@req.Book?.Title'?">
                            <i class="bi bi-check2 me-2"></i>Mark as Returned
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="bi bi-clock-history" style="font-size:3rem;color:var(--text-muted);display:block;margin-bottom:12px;"></i>
        <h5>No borrowed books</h5>
        <p class="text-muted">Books you borrow will appear here with their countdown timers.</p>
        <a asp-controller="Books" asp-action="Index" asp-route-TransactionType="Borrow" class="btn bb-btn-primary mt-2">
            Browse Books to Borrow
        </a>
    </div>
}
