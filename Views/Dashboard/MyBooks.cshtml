@* Dashboard/MyBooks.cshtml *@
@model List<BookBridge.Models.ViewModels.BookCardViewModel>
@{
    ViewData["Title"] = "My Books";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 style="font-family:var(--font-body);font-weight:600;margin-bottom:4px;">My Books</h2>
        <p class="text-muted mb-0">@Model.Count book@(Model.Count != 1 ? "s" : "") listed</p>
    </div>
    <a asp-controller="Books" asp-action="Create" class="btn bb-btn-primary">
        <i class="bi bi-plus-lg me-2"></i>List New Book
    </a>
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var book in Model)
        {
            <div class="col-6 col-md-4 col-xl-3">
                <div class="book-card position-relative">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="text-decoration-none">
                        <div class="book-img-wrap">
                            <img src="@(book.PrimaryImage ?? "/images/book-placeholder.png")" alt="@book.Title" class="book-img"
                                 onerror="this.src='/images/book-placeholder.png'" />
                            <span class="book-type-badge badge-@book.TransactionType.ToString().ToLower()">@book.TransactionType</span>
                        </div>
                        <div class="book-card-body">
                            <div class="book-title">@book.Title</div>
                            <div class="book-author">@book.Author</div>
                            <div class="d-flex gap-1 mt-2">
                                <span class="status-badge badge-@book.Status.ToString().ToLower()">@book.Status</span>
                            </div>
                        </div>
                    </a>
                    <div class="book-footer">
                        <a asp-controller="Books" asp-action="Edit" asp-route-id="@book.Id"
                           class="btn btn-sm bb-btn-ghost" style="font-size:0.75rem;padding:4px 10px;">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <form asp-controller="Books" asp-action="Delete" asp-route-id="@book.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:0.75rem;padding:4px 10px;"
                                    data-confirm="Remove '@book.Title'?">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <div style="font-size:4rem;margin-bottom:16px;">📚</div>
        <h4>No books listed yet</h4>
        <p class="text-muted">Start sharing your books with the BookBridge community.</p>
        <a asp-controller="Books" asp-action="Create" class="btn bb-btn-primary mt-3">
            <i class="bi bi-plus-lg me-2"></i>List Your First Book
        </a>
    </div>
}
