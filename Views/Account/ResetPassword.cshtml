@* Account/ResetPassword.cshtml *@
@model BookBridge.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Set New Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="brand-icon mb-3" style="width:48px;height:48px;font-size:1.4rem;margin:0 auto;background:linear-gradient(135deg,var(--emerald),#059669);">
            <i class="bi bi-shield-check"></i>
        </div>
        <h1 class="auth-title">Set New Password</h1>
        <p class="auth-subtitle">Choose a strong password for your account</p>
    </div>

    <form asp-action="ResetPassword" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>
        <input asp-for="Token" type="hidden" />
        <input asp-for="Email" type="hidden" />

        <div class="mb-3">
            <label class="form-label">New Password</label>
            <div class="input-icon-wrap">
                <i class="bi bi-lock input-icon"></i>
                <input asp-for="NewPassword" type="password" class="form-control bb-input input-with-icon"
                       placeholder="Min. 8 characters" id="newPass" />
                <button type="button" class="password-toggle" onclick="togglePassword('newPass', this)">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Confirm New Password</label>
            <div class="input-icon-wrap">
                <i class="bi bi-lock-fill input-icon"></i>
                <input asp-for="ConfirmPassword" type="password" class="form-control bb-input input-with-icon"
                       placeholder="Re-enter password" id="confirmPass" />
                <button type="button" class="password-toggle" onclick="togglePassword('confirmPass', this)">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
        </div>

        <button type="submit" class="btn bb-btn-primary w-100 btn-lg mb-4">
            Reset Password <i class="bi bi-check-lg ms-2"></i>
        </button>
    </form>
</div>


