@* VerifyPhone.cshtml *@
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    ViewData["Title"] = "Verify Phone";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    var email = (ViewData["Email"] as string) 
                ?? HttpContextAccessor.HttpContext?.Request.Query["email"].ToString() 
                ?? HttpContextAccessor.HttpContext?.Session.GetString("PendingVerificationEmail") 
                ?? "";
    var rawPhoneNumber = ViewData["PhoneNumber"] as string ?? "";
}

<div class="auth-card">
    <div class="auth-header">
        <div class="brand-icon mb-3" style="width:48px;height:48px;font-size:1.4rem;margin:0 auto; background: rgba(37, 99, 235, 0.1); color: var(--primary);">
            <i class="bi bi-phone-vibrate-fill"></i>
        </div>
        <h1 class="auth-title">Phone Verification</h1>
        <p class="auth-subtitle">Verify your phone number to secure your account</p>
    </div>

    <!-- Invisible reCAPTCHA container -->
    <div id="recaptcha-container"></div>

    <!-- Feedback alerts -->
    <div id="verifyMessage" class="alert d-none rounded-3 mb-4"></div>
    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4"></div>

    <form id="phoneVerificationForm">
        <!-- Step 1: Send SMS -->
        <div id="stepSendSms">
            <div class="mb-4">
                <label class="form-label fw-semibold">Enter your Phone Number</label>
                <div class="input-icon-wrap">
                    <i class="bi bi-phone input-icon"></i>
                    <input type="tel" id="phoneNumberInput" class="form-control bb-input input-with-icon" 
                           placeholder="03XX-XXXXXXX" value="@rawPhoneNumber" required />
                </div>
                <div class="form-text mt-1">We will send a 6-digit SMS verification code to this number.</div>
            </div>

            <button type="button" id="sendSmsBtn" class="btn bb-btn-primary w-100 btn-lg d-flex align-items-center justify-content-center gap-2">
                <span>Send Verification SMS</span> <i class="bi bi-send" id="sendSmsIcon"></i>
            </button>
        </div>

        <!-- Step 2: Verify Code (Hidden initially) -->
        <div id="stepVerifyCode" class="d-none">
            <div class="mb-4">
                <label class="form-label text-center d-block fw-semibold mb-3" style="font-size: 0.9rem;">
                    We sent an SMS code to <strong id="displayPhoneNumber" style="color: var(--primary); font-weight: 700;"></strong>
                </label>
                <div class="d-flex justify-content-center gap-2 mb-2" id="otpContainer">
                    @for (int i = 0; i < 6; i++)
                    {
                        <input type="text" class="form-control otp-box text-center" maxlength="1" pattern="\d*" inputmode="numeric" required />
                    }
                </div>
                <input type="hidden" id="otpFullCode" />
            </div>

            <button type="button" id="verifyOtpBtn" class="btn bb-btn-primary w-100 btn-lg mb-4 d-flex align-items-center justify-content-center gap-2">
                <span>Verify & Finish</span> <i class="bi bi-check-circle" id="verifyOtpIcon"></i>
            </button>

            <div class="text-center">
                <button type="button" id="changePhoneBtn" class="btn btn-link p-0 fw-600 text-decoration-none small text-muted" style="font-size: 0.82rem;">
                    <i class="bi bi-arrow-left me-1"></i>Change Phone Number
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script type="module">
        import { auth } from "/js/firebase-config.js";
        import { 
            RecaptchaVerifier, 
            signInWithPhoneNumber, 
            PhoneAuthProvider, 
            linkWithCredential 
        } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

        const sendSmsBtn = document.getElementById("sendSmsBtn");
        const sendSmsIcon = document.getElementById("sendSmsIcon");
        const verifyOtpBtn = document.getElementById("verifyOtpBtn");
        const verifyOtpIcon = document.getElementById("verifyOtpIcon");
        const phoneNumberInput = document.getElementById("phoneNumberInput");
        const displayPhoneNumber = document.getElementById("displayPhoneNumber");
        const stepSendSms = document.getElementById("stepSendSms");
        const stepVerifyCode = document.getElementById("stepVerifyCode");
        const verifyMessage = document.getElementById("verifyMessage");
        const changePhoneBtn = document.getElementById("changePhoneBtn");
        const otpBoxes = document.querySelectorAll(".otp-box");
        const fullCodeInput = document.getElementById("otpFullCode");

        let verificationResult = null;
        let formattedPhoneNumber = "";

        function showMessage(type, text) {
            verifyMessage.textContent = text;
            verifyMessage.className = `alert alert-${type} rounded-3 mb-4`;
            verifyMessage.classList.remove("d-none");
        }

        function clearMessage() {
            verifyMessage.classList.add("d-none");
            verifyMessage.textContent = "";
        }

        // Format raw Pakistani numbers to international E.164
        function formatPhoneE164(phone) {
            let clean = phone.replace(/[-\s()]/g, "");
            if (clean.startsWith("0")) {
                clean = "+92" + clean.substring(1);
            }
            if (!clean.startsWith("+")) {
                clean = "+" + clean;
            }
            return clean;
        }

        // Initialize invisible reCAPTCHA
        function initRecaptcha() {
            if (!window.recaptchaVerifier) {
                window.recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', {
                    'size': 'invisible',
                    'callback': (response) => {
                        // reCAPTCHA solved, proceed with phone verify
                    }
                });
            }
        }

        // 1. Send SMS Action
        sendSmsBtn.addEventListener("click", async () => {
            clearMessage();
            const rawPhone = phoneNumberInput.value.trim();
            if (!rawPhone) {
                showMessage("danger", "Please enter a valid phone number.");
                return;
            }

            formattedPhoneNumber = formatPhoneE164(rawPhone);
            displayPhoneNumber.textContent = formattedPhoneNumber;

            sendSmsBtn.disabled = true;
            sendSmsBtn.querySelector("span").textContent = "Sending code...";
            sendSmsIcon.className = "bi bi-arrow-repeat spin";

            try {
                initRecaptcha();
                
                // Call Firebase Phone Auth
                verificationResult = await signInWithPhoneNumber(auth, formattedPhoneNumber, window.recaptchaVerifier);
                
                showMessage("success", "Verification code sent to " + formattedPhoneNumber);
                stepSendSms.classList.add("d-none");
                stepVerifyCode.classList.remove("d-none");
            } catch (error) {
                console.error("Firebase SMS send failed:", error);
                let msg = "Failed to send SMS. Make sure the phone number is valid and has country code (e.g. +92).";
                if (error.code === "auth/invalid-phone-number") {
                    msg = "Invalid phone number format.";
                } else if (error.code === "auth/too-many-requests") {
                    msg = "Too many SMS requests. Please try again later.";
                }
                msg += ` (Firebase Error: ${error.code} - ${error.message})`;
                showMessage("danger", msg);
                sendSmsBtn.disabled = false;
                sendSmsBtn.querySelector("span").textContent = "Send Verification SMS";
                sendSmsIcon.className = "bi bi-send";
            }
        });

        // OTP inputs focus management
        otpBoxes.forEach((box, index) => {
            box.addEventListener("input", (e) => {
                const val = e.target.value;
                if (val.length === 1 && index < otpBoxes.length - 1) {
                    otpBoxes[index + 1].focus();
                }
                updateFullCode();
            });

            box.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && !box.value && index > 0) {
                    otpBoxes[index - 1].focus();
                }
            });
        });

        function updateFullCode() {
            let code = "";
            otpBoxes.forEach(box => code += box.value);
            fullCodeInput.value = code;
        }

        // 2. Verify OTP Action
        verifyOtpBtn.addEventListener("click", async () => {
            clearMessage();
            updateFullCode();
            const otpCode = fullCodeInput.value;

            if (otpCode.length !== 6) {
                showMessage("danger", "Please enter all 6 digits.");
                return;
            }

            verifyOtpBtn.disabled = true;
            verifyOtpBtn.querySelector("span").textContent = "Verifying...";
            verifyOtpIcon.className = "bi bi-arrow-repeat spin";

            try {
                // Link Phone credential to currently signed-in Email/Password user
                const credential = PhoneAuthProvider.credential(verificationResult.verificationId, otpCode);
                
                if (auth.currentUser) {
                    try {
                        await linkWithCredential(auth.currentUser, credential);
                    } catch (linkError) {
                        // If already linked, linkWithCredential will fail, we can ignore and get token
                        console.log("Linking note:", linkError.message);
                    }
                }

                // Get new token containing verified phone number info
                const token = auth.currentUser ? await auth.currentUser.getIdToken(true) : "";

                // Send to backend
                const response = await fetch("/Account/VerifyPhone", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        email: "@email",
                        idToken: token,
                        phoneNumber: formattedPhoneNumber
                    })
                });

                const data = await response.json();
                if (data.success) {
                    window.location.href = data.redirectUrl || "/Dashboard";
                } else {
                    showMessage("danger", data.message);
                    verifyOtpBtn.disabled = false;
                    verifyOtpBtn.querySelector("span").textContent = "Verify & Finish";
                    verifyOtpIcon.className = "bi bi-check-circle";
                }

            } catch (error) {
                console.error("SMS code confirmation failed:", error);
                let msg = "Invalid verification code. Please check your SMS and try again.";
                if (error.code === "auth/invalid-verification-code") {
                    msg = "Incorrect SMS code.";
                }
                showMessage("danger", msg);
                verifyOtpBtn.disabled = false;
                verifyOtpBtn.querySelector("span").textContent = "Verify & Finish";
                verifyOtpIcon.className = "bi bi-check-circle";
            }
        });

        // Return to change phone step
        changePhoneBtn.addEventListener("click", () => {
            clearMessage();
            stepVerifyCode.classList.add("d-none");
            stepSendSms.classList.remove("d-none");
            sendSmsBtn.disabled = false;
            sendSmsBtn.querySelector("span").textContent = "Send Verification SMS";
            sendSmsIcon.className = "bi bi-send";
            otpBoxes.forEach(box => box.value = "");
            fullCodeInput.value = "";
        });
    </script>

    <style>
        .otp-box {
            width: 48px;
            height: 56px;
            font-size: 1.5rem;
            font-weight: 700;
            border-radius: var(--radius-md);
            border: 2px solid var(--border);
            color: var(--text-primary);
            transition: all 0.2s ease;
        }
        .otp-box:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.15);
            background: #fff;
        }
        .spin {
            animation: spin 1s linear infinite;
            display: inline-block;
        }
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
}
